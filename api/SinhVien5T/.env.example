DB_URL=jdbc:mysql://localhost:3306/sinhvien5t?useSSL=false&serverTimezone=Asia/Bangkok&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
APP_TIMEZONE=Asia/Bangkok

JWT_SECRET=replace_with_base64_secret_at_least_32_bytes
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
AUTH_IDLE_TIMEOUT=10800000
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://172.20.10.3:3000

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ROOT_FOLDER=sinhvien5t
CLOUDINARY_AVATAR_FOLDER=users/avatars
CLOUDINARY_EVIDENCE_FOLDER=campaign/evidences
CLOUDINARY_AVATAR_MAX_BYTES=1048576
CLOUDINARY_EVIDENCE_MAX_BYTES=5242880
MULTIPART_MAX_FILE_SIZE=5MB
MULTIPART_MAX_REQUEST_SIZE=6MB

# REDIS CACHE (database 0 by default)
REDIS_CACHE_MODE=standalone
REDIS_CACHE_ENABLED=true
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_CACHE_DATABASE=0
REDIS_CACHE_PASSWORD=
REDIS_CACHE_TIMEOUT=2s
REDIS_CACHE_SHUTDOWN_TIMEOUT=100ms
REDIS_CACHE_POOL_MAX_ACTIVE=32
REDIS_CACHE_POOL_MAX_IDLE=16
REDIS_CACHE_POOL_MIN_IDLE=4
REDIS_CACHE_POOL_MAX_WAIT=500ms
REDIS_CACHE_CLUSTER_NODES=
REDIS_CACHE_CLUSTER_MAX_REDIRECTS=3
REDIS_CACHE_SENTINEL_MASTER=mymaster
REDIS_CACHE_SENTINEL_NODES=

# REDIS TOKEN/SESSION (database 1 by default)
REDIS_TOKEN_MODE=standalone
REDIS_TOKEN_ENABLED=true
REDIS_TOKEN_HOST=localhost
REDIS_TOKEN_PORT=6380
REDIS_TOKEN_DATABASE=0
REDIS_TOKEN_PASSWORD=
REDIS_TOKEN_TIMEOUT=2s
REDIS_TOKEN_SHUTDOWN_TIMEOUT=100ms
REDIS_TOKEN_POOL_MAX_ACTIVE=32
REDIS_TOKEN_POOL_MAX_IDLE=16
REDIS_TOKEN_POOL_MIN_IDLE=4
REDIS_TOKEN_POOL_MAX_WAIT=500ms
REDIS_TOKEN_CLUSTER_NODES=
REDIS_TOKEN_CLUSTER_MAX_REDIRECTS=3
REDIS_TOKEN_SENTINEL_MASTER=mymaster
REDIS_TOKEN_SENTINEL_NODES=

REDIS_KEY_PREFIX=sv5t
CACHE_TYPE=redis
CACHE_DEFAULT_TTL=10m
ACTUATOR_EXPOSURE=health,info,metrics,prometheus,caches
MANAGEMENT_HEALTH_SHOW_DETAILS=when_authorized
MANAGEMENT_HEALTH_REDIS_ENABLED=true
APP_NAME=sinhvien5t
